%% 冻结/解冻流程图

flowchart TB
    classDef start fill:#e3f2fd,stroke:#1976d2,stroke-width:2px,color:black
    classDef process fill:#fff3e0,stroke:#f57c00,stroke-width:1px,color:black
    classDef decision fill:#fce4ec,stroke:#c2185b,stroke-width:1px,color:black
    classDef data fill:#f3e5f5,stroke:#7b1fa2,stroke-width:1px,color:black
    classDef success fill:#e8f5e9,stroke:#388e3c,stroke-width:1px,color:black
    classDef error fill:#ffebee,stroke:#d32f2f,stroke-width:1px,color:black

    START([发起冻结/解冻请求]):::start

    %% ========== 冻结流程 ==========
    subgraph FREEZE["冻结流程（不生成凭证）"]
        direction TB
        F1[接收冻结请求<br/>account_no + freeze_amount]:::process
        F2[主账户余额不变<br/>t_account.balance 保持不变]:::data
        F3[可用子账户余额减少<br/>t_sub_account<br/>balance_type=1 可用余额<br/>balance -= freeze_amount]:::data
        F4[冻结子账户余额增加<br/>t_sub_account<br/>balance_type=2 冻结余额<br/>balance += freeze_amount]:::data
        F5[记录子账户明细<br/>t_sub_account_detail<br/>含 Pre/Post 余额<br/>不生成凭证和分录]:::data
        F6[创建冻结记录<br/>t_account_freeze_detail<br/>status=1 冻结<br/>记录 freeze_id]:::data
        F7[设置冻结有效期<br/>根据业务规则<br/>expire_time = now + duration]:::data
    end

    %% ========== 解冻流程 ==========
    subgraph UNFREEZE["解冻流程（基于原冻结记录）"]
        direction TB
        U1[接收解冻请求<br/>freeze_id 或 account_no]:::process
        U2[查询冻结记录<br/>t_account_freeze_detail<br/>status=1 冻结]:::process
        U3[主账户余额不变<br/>t_account.balance 保持不变]:::data
        U4[冻结子账户余额减少<br/>t_sub_account<br/>balance_type=2 冻结余额<br/>balance -= unfreeze_amount]:::data
        U5[可用子账户余额增加<br/>t_sub_account<br/>balance_type=1 可用余额<br/>balance += unfreeze_amount]:::data
        U6[记录子账户明细<br/>t_sub_account_detail<br/>含 Pre/Post 余额<br/>不生成凭证和分录]:::data
        U7[更新冻结记录<br/>t_account_freeze_detail<br/>status=2 已解冻]:::data
    end

    %% ========== 超时自动解冻 ==========
    subgraph AUTO_UNFREEZE["超时自动解冻（兜底任务）"]
        direction TB
        A1[定时任务扫描<br/>t_account_freeze_detail]:::process
        A2{expire_time < now<br/>且 status=1 冻结?}:::decision
        A3[自动触发解冻流程]:::process
        A4[记录自动解冻日志]:::data
    end

    %% ========== 冻结扣款 ==========
    subgraph FREEZE_DEDUCT["冻结扣款"]
        direction TB
        D1[直接在冻结额度上扣款]:::process
        D2[冻结子账户余额减少<br/>t_sub_account<br/>balance_type=2 冻结余额<br/>balance -= deduct_amount]:::data
        D3[主账户余额减少<br/>t_account.balance -= deduct_amount]:::data
        D4[记录账户明细<br/>t_account_detail<br/>t_sub_account_detail]:::data
        D5[更新冻结记录<br/>status=2 已解冻<br/>或部分解冻]:::data
    end

    %% ========== 余额关系示例 ==========
    subgraph EXAMPLE["余额关系示例"]
        direction TB
        E1[初始状态：<br/>主账户余额：1000<br/>可用子账户：1000<br/>冻结子账户：0]:::data
        E2[冻结 300 后：<br/>主账户余额：1000 不变<br/>可用子账户：700 减少<br/>冻结子账户：300 增加]:::data
        E3[解冻 100 后：<br/>主账户余额：1000 不变<br/>可用子账户：800 增加<br/>冻结子账户：200 减少]:::data
        E4[冻结扣款 200 后：<br/>主账户余额：800 减少<br/>可用子账户：800 不变<br/>冻结子账户：0 减少]:::data
    end

    END([冻结/解冻完成]):::success

    %% 流程连线
    START --> F1
    START --> U1

    F1 --> F2
    F2 --> F3
    F3 --> F4
    F4 --> F5
    F5 --> F6
    F6 --> F7
    F7 --> END

    U1 --> U2
    U2 --> U3
    U3 --> U4
    U4 --> U5
    U5 --> U6
    U6 --> U7
    U7 --> END

    A1 --> A2
    A2 -->|是| A3
    A2 -->|否| A1
    A3 --> A4
    A4 --> U1

    D1 --> D2
    D2 --> D3
    D3 --> D4
    D4 --> D5
    D5 --> END

    E1 --> E2
    E2 --> E3
    E3 --> E4
